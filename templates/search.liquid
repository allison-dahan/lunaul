<div class="page-wrap"><h1 class="page-heading">SEARCH</h1><form action="/search" method="get" style="display:flex;gap:12px;border-bottom:1px solid #e5e5e5;padding-bottom:14px;margin-bottom:32px;"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="SEARCH PRODUCTS..." style="flex:1;border:none;outline:none;font-family:inherit;font-size:12px;letter-spacing:.04em;background:transparent;"><button type="submit" style="font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:#999;background:none;border:none;font-family:inherit;cursor:pointer;">GO</button></form>{% if search.performed %}{% if search.results.size > 0 %}<p style="font-size:10px;color:#999;letter-spacing:.2em;text-transform:uppercase;margin-bottom:28px;">{{ search.results_count }} results for &ldquo;{{ search.terms }}&rdquo;</p><div class="prod-grid">{% for item in search.results %}{% if item.object_type == "product" %}{% render "product-card", product: item %}{% endif %}{% endfor %}</div>{% else %}<p style="text-align:center;font-size:10px;color:#999;letter-spacing:.22em;text-transform:uppercase;padding:64px 0;">No results for &ldquo;{{ search.terms }}&rdquo;.</p>{% endif %}{% endif %}</div>