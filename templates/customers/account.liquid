<div class="page-wrap"><h1 class="page-heading">MY ACCOUNT</h1><p style="font-size:11px;margin-bottom:28px;">Hello, {{ customer.first_name }}. <a href="/account/logout" style="color:#999;text-decoration:underline;">Log out</a></p>{% if customer.orders.size == 0 %}<p style="font-size:10px;color:#999;letter-spacing:.2em;text-transform:uppercase;">No orders yet.</p>{% else %}<table style="width:100%;border-collapse:collapse;font-size:10px;letter-spacing:.12em;text-transform:uppercase;"><thead><tr style="border-bottom:1px solid #e5e5e5;"><th style="text-align:left;padding:8px 0;font-weight:500;">ORDER</th><th style="text-align:left;padding:8px 0;font-weight:500;">DATE</th><th style="text-align:left;padding:8px 0;font-weight:500;">STATUS</th><th style="text-align:right;padding:8px 0;font-weight:500;">TOTAL</th></tr></thead><tbody>{% for o in customer.orders %}<tr style="border-bottom:1px solid #e5e5e5;"><td style="padding:10px 0;"><a href="{{ o.customer_url }}" style="color:#999;">{{ o.name }}</a></td><td style="padding:10px 0;color:#999;">{{ o.created_at | date: "%b %d, %Y" }}</td><td style="padding:10px 0;color:#999;">{{ o.financial_status }}</td><td style="padding:10px 0;text-align:right;">{{ o.total_price | money }}</td></tr>{% endfor %}</tbody></table>{% endif %}</div>