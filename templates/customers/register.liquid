<div class="page-wrap" style="max-width:380px;"><h1 class="page-heading">CREATE ACCOUNT</h1>{% form "create_customer" %}{{ form.errors | default_errors }}<input class="form-field" type="text" name="customer[first_name]" placeholder="FIRST NAME" autocomplete="given-name"><input class="form-field" type="text" name="customer[last_name]" placeholder="LAST NAME" autocomplete="family-name"><input class="form-field" type="email" name="customer[email]" placeholder="EMAIL" autocomplete="email" required><input class="form-field" type="password" name="customer[password]" placeholder="PASSWORD" autocomplete="new-password" required><button type="submit" class="btn-primary">CREATE ACCOUNT</button><div class="form-links"><a href="/account/login">ALREADY HAVE AN ACCOUNT?</a></div>{% endform %}</div>