<div class="page-wrap" style="max-width:380px;"><h1 class="page-heading">LOGIN</h1>{% form "customer_login" %}{{ form.errors | default_errors }}<input class="form-field" type="email" name="customer[email]" placeholder="EMAIL" autocomplete="email" required><input class="form-field" type="password" name="customer[password]" placeholder="PASSWORD" autocomplete="current-password" required><button type="submit" class="btn-primary">SIGN IN</button><div class="form-links"><a href="/account/register">CREATE ACCOUNT</a><a href="/account/forgot_password">FORGOT PASSWORD?</a></div>{% endform %}</div>