<div class="insta-section" data-fade>
  <span class="sec-row__title" style="display:block;margin-bottom:6px;">{{ section.settings.heading | default: 'FOLLOW US' }}</span>
  {% if section.settings.handle != blank %}
    <a class="insta-handle" href="https://instagram.com/{{ section.settings.handle | remove: '@' }}" target="_blank" rel="noopener">{{ section.settings.handle }}</a>
  {% endif %}
  <div class="insta-grid">
    {% for block in section.blocks %}{% if block.type == 'photo' %}
    <a class="insta-item" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }} target="_blank" rel="noopener">
      {% if block.settings.image != blank %}
        <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
      {% endif %}
    </a>
    {% endif %}{% endfor %}
  </div>
</div>
{% schema %}{"name":"Instagram","settings":[{"type":"text","id":"heading","label":"Heading","default":"FOLLOW US"},{"type":"text","id":"handle","label":"Handle","default":"@yourbrand"}],"blocks":[{"type":"photo","name":"Photo","settings":[{"type":"image_picker","id":"image","label":"Photo"},{"type":"url","id":"link","label":"Post link"}]}],"presets":[{"name":"Instagram","blocks":[{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"}]}]}{% endschema %}