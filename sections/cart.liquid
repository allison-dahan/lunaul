<div class="cart-page">

  {% if cart.item_count == 0 %}
    <div class="cart-empty-state">
      <p>YOUR CART IS EMPTY.</p>
      <a href="/collections/all">CONTINUE SHOPPING</a>
    </div>
  {% else %}

    <form action="/cart" method="post" id="cartForm">

      <!-- Line items -->
      <div class="cart-lines">
        {% for item in cart.items %}
          <div class="cart-line">

            <!-- Left: checkbox + image -->
            <div class="cart-line__left">
              <input type="checkbox" class="cart-line__check" checked>
              <a href="{{ item.url }}" class="cart-line__img-wrap">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
                {% endif %}
              </a>
            </div>

            <!-- Middle: info -->
            <div class="cart-line__info" style="display:flex;flex-direction:column;gap:4px;min-width:0;">
              <div style="font-size:11px;font-weight:600;color:#000;letter-spacing:0.04em;">{{ item.title }}</div>
              {% if item.variant_title and item.variant_title != 'Default Title' %}
                <div style="font-size:10px;color:#999;letter-spacing:0.1em;text-transform:uppercase;">{{ item.variant_title }}</div>
              {% endif %}
            </div>

            <!-- Right: qty, price, remove -->
            <div class="cart-line__right">
              <div class="cart-line__qty-price">
                <button type="button" class="cart-line__qty-btn" data-key="{{ item.key }}" data-action="inc">&#9650;</button>
                <span class="cart-line__qty-num">{{ item.quantity }}</span>
                <button type="button" class="cart-line__qty-btn" data-key="{{ item.key }}" data-action="dec">&#9660;</button>
              </div>
              <span class="cart-line__price">{{ item.original_line_price | money }}</span>
              <a href="{{ item.url_to_remove }}" class="cart-line__remove">REMOVE</a>
            </div>

          </div>
        {% endfor %}
      </div>

      <!-- Totals -->
      <div class="cart-totals">
        <div class="cart-totals__row">
          <span>SUBTOTAL</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-totals__row">
          <span>SHIPPING</span>
          <span>FREE</span>
        </div>
        <div class="cart-totals__row cart-totals__row--total">
          <span>TOTAL</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
      </div>

      <!-- Buttons -->
      <div class="cart-actions">
        <button type="submit" name="checkout" class="cart-btn cart-btn--outline">ORDER SELECTED</button>
        <button type="submit" name="checkout" class="cart-btn cart-btn--outline">ORDER ALL</button>
      </div>

    </form>

  {% endif %}

</div>

<style>
/* Make cart page fill full viewport height with footer pinned to bottom */
.template-cart #page-push {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}
.template-cart #main {
  flex: 1;
}
.template-cart .site-footer {
  border-top: none;
}

.cart-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 24px 80px;
}

/* Empty */
.cart-empty-state {
  text-align: center;
  padding: 80px 0;
  display: flex; flex-direction: column; gap: 20px; align-items: center;
}
.cart-empty-state p {
  font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: #999;
}
.cart-empty-state a {
  font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
  border-bottom: 1px solid currentColor; padding-bottom: 2px;
}

/* Line items */
.cart-lines { border-top: 1px solid #e5e5e5; }
.cart-line {
  display: grid;
  grid-template-columns: 116px 1fr auto;
  align-items: center;
  gap: 20px;
  padding: 20px 0;
  border-bottom: 1px solid #e5e5e5;
}
.cart-line__left {
  display: flex; align-items: center; gap: 10px;
}
.cart-line__check { width: 14px; height: 14px; accent-color: #000; cursor: pointer; flex-shrink: 0; }
.cart-line__img-wrap { display: block; width: 90px; flex-shrink: 0; }
.cart-line__img-wrap img { width: 90px; height: 90px; object-fit: cover; display: block; background: #f5f5f5; }
.cart-line__info {
  display: flex;
  flex-direction: column;
  gap: 5px;
  min-width: 0;
}
.cart-line__title {
  display: block; font-size: 11px; font-weight: 600;
  letter-spacing: 0.04em; line-height: 1.3; color: #000;
}
.cart-line__variant-label {
  display: block; font-size: 10px; color: #999;
  letter-spacing: 0.1em; text-transform: uppercase;
}
.cart-line__right {
  display: flex;
  align-items: center;
  gap: 20px;
  justify-content: flex-end;
}
.cart-line__qty-price { display: flex; flex-direction: column; align-items: center; gap: 2px; }
.cart-line__qty-btn {
  background: none; border: none; cursor: pointer;
  font-size: 8px; color: #999; line-height: 1; padding: 2px; transition: color 0.2s;
}
.cart-line__qty-btn:hover { color: #000; }
.cart-line__qty-num { font-size: 11px; color: #000; min-width: 20px; text-align: center; }
.cart-line__price { font-size: 11px; font-weight: 600; color: #000; }
.cart-line__remove {
  font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
  background: #000; color: #fff; padding: 10px 14px;
  display: inline-block; text-align: center; transition: opacity 0.2s;
}
.cart-line__remove:hover { opacity: 0.7; }

/* Totals */
.cart-totals {
  margin-top: 0;
  border-top: none;
  background: #f5f5f5;
}
.cart-totals__row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 24px;
  font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
  border-bottom: 1px solid #eee;
}
.cart-totals__row--total {
  background: #000; color: #fff;
  font-weight: 600; border-bottom: none;
}

/* Buttons */
.cart-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
  margin-top: 4px;
}
.cart-btn {
  padding: 16px;
  font-family: inherit;
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  border: 1px solid #000;
  background: none;
  color: #000;
}
.cart-btn:hover {
  background: #000;
  color: #fff;
}
@media (max-width: 600px) {
  .cart-line {
    grid-template-columns: 80px 1fr;
    grid-template-rows: auto auto;
  }
  .cart-line__right {
    grid-column: 1 / -1;
    justify-content: flex-start;
    padding-left: 0;
  }
}
</style>

<script>
// Qty buttons on cart page
document.querySelectorAll('.cart-line__qty-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const key    = btn.dataset.key;
    const action = btn.dataset.action;
    const numEl  = btn.closest('.cart-line__qty-price')?.querySelector('.cart-line__qty-num');
    const current = parseInt(numEl?.textContent || '1');
    const newQty  = action === 'inc' ? current + 1 : Math.max(0, current - 1);
    await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: newQty })
    });
    location.reload();
  });
});
</script>

{% schema %}
{ "name": "Cart" }
{% endschema %}
