<div class="page-wrap" style="max-width:840px;margin:0 auto;">
  <h1 class="page-heading">CART ({{ cart.item_count }})</h1>
  {% if cart.item_count == 0 %}
    <div style="text-align:center;padding:64px 0;">
      <p style="font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:#999;margin-bottom:22px;">Your cart is empty.</p>
      <a href="/collections/all" style="font-size:10px;letter-spacing:.26em;text-transform:uppercase;border-bottom:1px solid currentColor;padding-bottom:2px;">CONTINUE SHOPPING</a>
    </div>
  {% else %}
    <form action="/cart" method="post">
      {% for item in cart.items %}
        <div style="display:grid;grid-template-columns:90px 1fr;gap:18px;padding:20px 0;border-bottom:1px solid #e5e5e5;">
          <a href="{{ item.url }}"><img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" style="width:90px;aspect-ratio:3/4;object-fit:cover;background:#f2f2f2;" loading="lazy"></a>
          <div style="display:flex;flex-direction:column;justify-content:space-between;">
            <div>
              <a href="{{ item.url }}" style="font-size:11px;display:block;margin-bottom:4px;">{{ item.product_title }}</a>
              {% if item.variant_title and item.variant_title != 'Default Title' %}<p style="font-size:10px;color:#999;letter-spacing:.12em;text-transform:uppercase;">{{ item.variant_title }}</p>{% endif %}
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <span style="font-size:11px;">{{ item.final_line_price | money }}</span>
              <div style="display:flex;align-items:center;gap:10px;">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:38px;border:1px solid #e5e5e5;text-align:center;font-family:inherit;font-size:11px;padding:3px;outline:none;">
                <a href="{{ item.url_to_remove }}" style="font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:#bbb;">REMOVE</a>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
      <div style="display:flex;justify-content:flex-end;margin-top:28px;">
        <div style="width:280px;">
          <div style="display:flex;justify-content:space-between;font-size:10px;letter-spacing:.22em;text-transform:uppercase;margin-bottom:6px;"><span>SUBTOTAL</span><span>{{ cart.total_price | money }}</span></div>
          <p style="font-size:10px;color:#bbb;margin-bottom:16px;">Shipping and taxes calculated at checkout</p>
          <button type="submit" name="checkout" class="btn-checkout">CHECKOUT</button>
          <button type="submit" name="update" style="display:block;width:100%;background:none;border:1px solid #e5e5e5;padding:13px;font-size:10px;letter-spacing:.26em;text-transform:uppercase;cursor:pointer;font-family:inherit;margin-top:9px;">UPDATE CART</button>
        </div>
      </div>
    </form>
  {% endif %}
</div>
{% schema %}{"name":"Cart"}{% endschema %}