{% if section.settings.show %}
<div class="announcement-bar">
  {% if section.settings.link != blank %}<a href="{{ section.settings.link }}">{% endif %}
  {{ section.settings.text }}
  {% if section.settings.link != blank %}</a>{% endif %}
</div>
{% endif %}
{% schema %}{"name":"Announcement Bar","settings":[{"type":"checkbox","id":"show","label":"Show","default":true},{"type":"text","id":"text","label":"Text","default":"FREE SHIPPING ON ORDERS OVER $100"},{"type":"url","id":"link","label":"Link"}],"presets":[{"name":"Announcement Bar"}]}{% endschema %}