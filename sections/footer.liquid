<footer class="site-footer">
  <div class="footer__top">
    <div class="footer__wordmark">
      {% if section.settings.logo %}
        <img src="{{ section.settings.logo | image_url: width: 180 }}" alt="{{ shop.name }}">
      {% else %}
        {{ shop.name }}
      {% endif %}
    </div>
    <div class="footer__sns">
      {% if settings.social_instagram != blank %}<a href="{{ settings.social_instagram }}" target="_blank" rel="noopener">INSTAGRAM</a>{% endif %}
      {% if settings.social_facebook  != blank %}<a href="{{ settings.social_facebook }}"  target="_blank" rel="noopener">FACEBOOK</a>{% endif %}
      {% if settings.social_tiktok    != blank %}<a href="{{ settings.social_tiktok }}"    target="_blank" rel="noopener">TIKTOK</a>{% endif %}
      {% if settings.social_youtube   != blank %}<a href="{{ settings.social_youtube }}"   target="_blank" rel="noopener">YOUTUBE</a>{% endif %}
    </div>
  </div>
  <div class="footer__cols">
    {% for block in section.blocks %}{% if block.type == 'col' %}
    <div class="footer__col" {{ block.shopify_attributes }}>
      {% if block.settings.title != blank %}<p class="footer__col-title">{{ block.settings.title }}</p>{% endif %}
      <ul>{% for link in linklists[block.settings.menu].links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul>
    </div>
    {% endif %}{% endfor %}
  </div>
  <div class="footer__bottom">
    <p class="footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="footer__legal">{% for link in linklists[section.settings.legal_menu].links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}</div>
  </div>
</footer>
{% schema %}{"name":"Footer","settings":[{"type":"image_picker","id":"logo","label":"Footer logo"},{"type":"link_list","id":"legal_menu","label":"Legal links","default":"footer"}],"blocks":[{"type":"col","name":"Column","settings":[{"type":"text","id":"title","label":"Title","default":"SHOP"},{"type":"link_list","id":"menu","label":"Menu","default":"main-menu"}]}],"presets":[{"name":"Footer","blocks":[{"type":"col","settings":{"title":"SHOP"}},{"type":"col","settings":{"title":"ARCHIVE"}},{"type":"col","settings":{"title":"INFO"}},{"type":"col","settings":{"title":"HELP"}}]}]}{% endschema %}