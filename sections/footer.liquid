<footer class="site-footer">
  <div class="footer__inner">

    <!-- LEFT: social links stacked vertically -->
    <div class="footer__social">
      {% for link in linklists[section.settings.social_menu].links %}
        <a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.title }}</a>
      {% endfor %}
    </div>

    <!-- RIGHT: footer links -->
    <div class="footer__links">
      <div class="footer__links-col">
        {% for link in linklists[section.settings.menu_1].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>

  </div>
</footer>

<style>
.site-footer {
  border-top: 1px solid #e5e5e5;
  padding: 40px 24px 32px;
}
.footer__inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

/* Social — stacked vertically, left-aligned */
.footer__social {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.footer__social a {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #000;
  transition: opacity 0.2s;
}
.footer__social a:hover { opacity: 0.45; }

/* Right: two columns of links */
.footer__links {
  display: flex;
  align-items: flex-start;
  gap: 48px;
}
.footer__links-col {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 24px;
}
.footer__links-col a {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #000;
  transition: opacity 0.2s;
}
.footer__links-col a:hover { opacity: 0.45; }

@media (max-width: 600px) {
  .footer__inner {
    flex-direction: column;
    gap: 28px;
  }
  .footer__links {
    flex-wrap: wrap;
    gap: 16px;
  }
}
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "social_menu",
      "label": "Social links menu"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Footer menu 1"
    }
  ]
}
{% endschema %}
