<div class="archive-wrap">
  {% for block in section.blocks %}
    {% if block.type == 'image' and block.settings.image != blank %}
      <a class="archive-item"
         href="#"
         data-full="{{ block.settings.image | image_url: width: 2000 }}"
         data-alt="{{ block.settings.image.alt | default: '' | escape }}"
         {{ block.shopify_attributes }}>
        {{
          block.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            alt: block.settings.image.alt | default: '',
            widths: '600, 900, 1400',
            sizes: '(max-width: 767px) 33vw, 50vw'
        }}
      </a>
    {% endif %}
  {% endfor %}
</div>

<!-- Lightbox -->
<div class="archive-lightbox" id="archiveLightbox">
  <button class="archive-lightbox__close" id="archiveLightboxClose">&#215;</button>
  <button class="archive-lightbox__arrow archive-lightbox__arrow--prev" id="archivePrev">&#8249;</button>
  <img class="archive-lightbox__img" id="archiveLightboxImg" src="" alt="">
  <button class="archive-lightbox__arrow archive-lightbox__arrow--next" id="archiveNext">&#8250;</button>
</div>

<style>
.archive-wrap {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  padding: 0 24px;
}
.archive-item {
  display: block;
  overflow: hidden;
  cursor: zoom-in;
}
.archive-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.archive-item:hover img {
  transform: scale(1.02);
}

@media (max-width: 767px) {
  .archive-wrap {
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    padding: 0 12px;
  }
  .archive-item img {
    aspect-ratio: 1;
    object-fit: cover;
  }
}

/* Lightbox */
.archive-lightbox {
  display: none;
  position: fixed; inset: 0;
  background: rgba(255,255,255,0.92);
  z-index: 2000;
  align-items: center;
  justify-content: center;
}
.archive-lightbox.open { display: flex; }
.archive-lightbox__img {
  max-width: 80vw;
  max-height: 85vh;
  object-fit: contain;
  width: auto;
  height: auto;
}
.archive-lightbox__close {
  position: absolute; top: 20px; right: 24px;
  background: none; border: none; cursor: pointer;
  font-size: 28px; color: #000; line-height: 1; opacity: 0.5;
  transition: opacity 0.2s;
}
.archive-lightbox__close:hover { opacity: 1; }
.archive-lightbox__arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer;
  font-size: 32px; color: #000; opacity: 0.4;
  padding: 16px; transition: opacity 0.2s; font-family: serif; line-height: 1;
}
.archive-lightbox__arrow:hover { opacity: 1; }
.archive-lightbox__arrow--prev { left: 16px; }
.archive-lightbox__arrow--next { right: 16px; }
</style>

<script>
(function () {
  const lightbox = document.getElementById('archiveLightbox');
  const lbImg    = document.getElementById('archiveLightboxImg');
  const lbClose  = document.getElementById('archiveLightboxClose');
  const lbPrev   = document.getElementById('archivePrev');
  const lbNext   = document.getElementById('archiveNext');
  const items    = Array.from(document.querySelectorAll('.archive-item'));
  let current    = 0;

  function goTo(index) {
    current = (index + items.length) % items.length;
    lbImg.src = items[current].dataset.full;
    lbImg.alt = items[current].dataset.alt;
  }

  items.forEach((item, i) => {
    item.addEventListener('click', e => {
      e.preventDefault();
      current = i;
      goTo(i);
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  lbPrev.addEventListener('click', () => goTo(current - 1));
  lbNext.addEventListener('click', () => goTo(current + 1));
  lbClose.addEventListener('click', close);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', e => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });
})();
</script>

{% schema %}
{
  "name": "Archive",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url",          "id": "link",  "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Archive",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
