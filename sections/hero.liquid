{% assign ht = section.settings.hero_type %}
<section class="hero">
  <div class="hero__media">
    {% if ht == 'video' and section.settings.youtube_id != blank %}
      <iframe src="https://www.youtube.com/embed/{{ section.settings.youtube_id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.youtube_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1" allow="autoplay;encrypted-media" title="{{ shop.name }}"></iframe>
    {% elsif ht == 'video' and section.settings.video != blank %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
    {% elsif section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 2200 }}"
           srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1400 }} 1400w, {{ section.settings.image | image_url: width: 2200 }} 2200w"
           sizes="100vw" alt="{{ section.settings.image.alt | escape }}" loading="eager" fetchpriority="high">
    {% endif %}
  </div>
  {% if section.settings.heading != blank or section.settings.btn_label != blank %}
  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}<p style="font-size:10px;letter-spacing:.3em;text-transform:uppercase;opacity:.7;margin-bottom:10px;color:#fff;">{{ section.settings.eyebrow }}</p>{% endif %}
    {% if section.settings.heading != blank %}<h1 class="hero__title">{{ section.settings.heading }}</h1>{% endif %}
    {% if section.settings.btn_label != blank %}<a class="hero__cta" href="{{ section.settings.btn_url | default: '/collections/all' }}">{{ section.settings.btn_label }}</a>{% endif %}
  </div>
  {% endif %}
</section>
{% schema %}{"name":"Hero","settings":[{"type":"select","id":"hero_type","label":"Media type","options":[{"value":"image","label":"Image"},{"value":"video","label":"Video"}],"default":"image"},{"type":"image_picker","id":"image","label":"Image"},{"type":"video","id":"video","label":"Video (Shopify-hosted)"},{"type":"text","id":"youtube_id","label":"YouTube video ID"},{"type":"text","id":"eyebrow","label":"Eyebrow text"},{"type":"text","id":"heading","label":"Heading"},{"type":"text","id":"btn_label","label":"Button label"},{"type":"url","id":"btn_url","label":"Button URL"}],"presets":[{"name":"Hero","settings":{"hero_type":"image"}}]}{% endschema %}