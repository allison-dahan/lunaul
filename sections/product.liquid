{% assign cv = product.selected_or_first_available_variant %}
<div class="product-layout">
  <!-- GALLERY: 2-col grid, arrow advances one at a time -->
  <div class="pgallery">
    <div class="pgallery__viewport">
      <div class="pgallery__track" id="galleryTrack">
        {% for img in product.images %}
          <div class="pgallery__slide">
            <img src="{{ img | image_url: width: 1400 }}"
                 srcset="{{ img | image_url: width: 700 }} 700w, {{ img | image_url: width: 1400 }} 1400w"
                 sizes="25vw"
                 alt="{{ img.alt | default: product.title | escape }}"
                 data-full="{{ img | image_url: width: 2000 }}"
                 class="pgallery__zoomable"
                 {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}>
          </div>
        {% endfor %}
      </div>
      <button class="pgallery__arrow pgallery__arrow--prev" id="galleryPrev">&#8249;</button>
      <button class="pgallery__arrow pgallery__arrow--next" id="galleryNext">&#8250;</button>
    </div>
  </div>

  <!-- INFO PANEL -->
  <div class="pinfo">

    <h1 class="pinfo__title">{{ product.title }}</h1>

    <div class="pinfo__pricing">
      {% unless cv.available %}
        <span class="pinfo__sold-out">SOLD OUT</span>
      {% else %}
        {% if cv.compare_at_price > cv.price %}
          <div class="pinfo__price-row">
            <span class="pinfo__label">PRICE</span>
            <span class="pinfo__compare">{{ cv.compare_at_price | money }}</span>
          </div>
          <div class="pinfo__price-row">
            <span class="pinfo__label">SALE</span>
            <span class="pinfo__sale">{{ cv.price | money }}</span>
          </div>
        {% else %}
          <div class="pinfo__price-row">
            <span class="pinfo__label">PRICE</span>
            <span>{{ cv.price | money }}</span>
          </div>
        {% endif %}
      {% endunless %}
    </div>

    <form action="/cart/add" method="post" id="atc-form" data-atc-form>
      <input type="hidden" name="id" value="{{ cv.id }}" id="variantId">

      {% unless product.has_only_default_variant %}
        {% for opt in product.options_with_values %}
          <div class="pinfo__size-row">
            <span class="pinfo__label">{{ opt.name | upcase }}</span>
            <div class="variant__opts">
              {% for val in opt.values %}
                {% assign val_available = false %}
                {% for v in product.variants %}
                  {% if v.available %}
                    {% if opt.position == 1 and v.option1 == val %}{% assign val_available = true %}{% endif %}
                    {% if opt.position == 2 and v.option2 == val %}{% assign val_available = true %}{% endif %}
                    {% if opt.position == 3 and v.option3 == val %}{% assign val_available = true %}{% endif %}
                  {% endif %}
                {% endfor %}
                <button type="button"
                  class="vbtn{% unless val_available %} vbtn--sold-out{% endunless %}"
                  data-group="{{ opt.name }}"
                  data-val="{{ val }}"
                  {% unless val_available %}disabled{% endunless %}>{{ val }}</button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endunless %}

    </form>

    <!-- Selected item bar — appears when a size is chosen -->
    <div class="selected-bar" id="selectedBar" style="display:none;">
      <span class="selected-bar__name" id="selectedName"></span>
      <div class="selected-bar__right">
        <div class="selected-bar__qty">
          <button class="selected-bar__qty-btn" id="qtyUp">&#8593;</button>
          <span class="selected-bar__qty-num" id="qtyNum">1</span>
          <button class="selected-bar__qty-btn" id="qtyDown">&#8595;</button>
        </div>
        <button class="selected-bar__remove" id="selectedRemove">&#10005;</button>
      </div>
    </div>

    <div class="accordion">
      {% if product.description != blank %}
      <div class="acc-item">
        <button class="acc-trigger"><span>DESCRIPTION</span><span class="acc-chevron">&#8250;</span></button>
        <div class="acc-body">{{ product.description }}</div>
      </div>
      {% endif %}
      {% if section.settings.size_text != blank %}
      <div class="acc-item">
        <button class="acc-trigger"><span>SIZE</span><span class="acc-chevron">&#8250;</span></button>
        <div class="acc-body">{{ section.settings.size_text }}</div>
      </div>
      {% endif %}
      {% if section.settings.shipping_text != blank %}
      <div class="acc-item">
        <button class="acc-trigger"><span>SHIPPING &amp; RETURN</span><span class="acc-chevron">&#8250;</span></button>
        <div class="acc-body">{{ section.settings.shipping_text }}</div>
      </div>
      {% endif %}
    </div>

    <div class="pinfo__buttons{% unless cv.available %} pinfo__buttons--sold-out{% endunless %}">
      {% if cv.available %}
        <a href="/checkout" class="btn-buy-now">BUY NOW</a>
      {% endif %}
      <button type="submit" form="atc-form" class="btn-add-cart"{% unless cv.available %} disabled{% endunless %}>
        {% if cv.available %}ADD CART{% else %}SOLD OUT{% endif %}
      </button>
    </div>

  </div>
</div>
<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox__close" id="lightboxClose">&#215;</button>
  <img class="lightbox__img" id="lightboxImg" src="" alt="">
</div>

<script>
// Lightbox
const lightbox     = document.getElementById('lightbox');
const lightboxImg  = document.getElementById('lightboxImg');
const lightboxClose = document.getElementById('lightboxClose');

document.querySelectorAll('.pgallery__zoomable').forEach(img => {
  img.style.cursor = 'zoom-in';
  img.addEventListener('click', () => {
    lightboxImg.src = img.dataset.full;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
});

lightboxClose?.addEventListener('click', closeLightbox);
lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

function closeLightbox() {
  lightbox.classList.remove('open');
  document.body.style.overflow = '';
}

(function () {
  const track   = document.getElementById('galleryTrack');
  const prevBtn = document.getElementById('galleryPrev');
  const nextBtn = document.getElementById('galleryNext');
  if (!track) return;

  const slides = track.querySelectorAll('.pgallery__slide');
  const max    = Math.max(0, slides.length - 2);
  let current  = 0;

  function goTo(index) {
    current = Math.max(0, Math.min(index, max));
    track.style.transform = `translateX(-${current * 50}%)`;
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current === max;
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));

  let startX = 0;
  track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  goTo(0);
})();

// Selected size bar
const selectedBar    = document.getElementById('selectedBar');
const selectedName   = document.getElementById('selectedName');
const qtyNum         = document.getElementById('qtyNum');
const qtyUp          = document.getElementById('qtyUp');
const qtyDown        = document.getElementById('qtyDown');
const selectedRemove = document.getElementById('selectedRemove');
const qtyInput       = document.querySelector('[name="quantity"]') || (() => {
  const i = document.createElement('input');
  i.type = 'hidden'; i.name = 'quantity'; i.value = '1';
  document.querySelector('[data-atc-form]')?.appendChild(i);
  return i;
})();

let qty = 1;

function showBar(label) {
  selectedName.textContent = '{{ product.title }}' + (label ? ' - ' + label : '');
  selectedBar.style.display = 'flex';
  qty = 1;
  qtyNum.textContent = qty;
  if (qtyInput) qtyInput.value = qty;
}

function hideBar() {
  selectedBar.style.display = 'none';
  document.querySelectorAll('.vbtn').forEach(b => b.classList.remove('sel'));
}

document.querySelectorAll('.vbtn').forEach(btn => {
  btn.addEventListener('click', () => {
    const group = btn.dataset.group;
    document.querySelectorAll(`.vbtn[data-group="${group}"]`).forEach(b => b.classList.remove('sel'));
    btn.classList.add('sel');
    showBar(btn.dataset.val);
  });
});

qtyUp?.addEventListener('click', () => {
  qty = Math.min(qty + 1, 99);
  qtyNum.textContent = qty;
  if (qtyInput) qtyInput.value = qty;
});

qtyDown?.addEventListener('click', () => {
  qty = Math.max(qty - 1, 1);
  qtyNum.textContent = qty;
  if (qtyInput) qtyInput.value = qty;
});

selectedRemove?.addEventListener('click', hideBar);
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "richtext", "id": "size_text", "label": "Size text" },
    { "type": "richtext", "id": "shipping_text", "label": "Shipping & Return", "default": "<p>Free standard shipping on orders over $100. Returns accepted within 30 days.</p>" }
  ]
}
{% endschema %}