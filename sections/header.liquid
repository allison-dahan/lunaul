<header class="site-header" id="siteHeader" role="banner">
  <div class="header__inner">

    <!-- MOBILE: MENU button (hidden on desktop) -->
    <button class="header__menu-btn" id="menuBtn" aria-label="Open menu">MENU</button>

    <!-- DESKTOP: left nav (hidden on mobile) -->
    <nav class="header__nav" role="navigation">
      {% for link in linklists[section.settings.menu].links %}
        {% if link.links != blank %}
          <div class="nav-item">{{ link.title }}
            <div class="nav-item__drop">
              {% for child in link.links %}<a href="{{ child.url }}">{{ child.title }}</a>{% endfor %}
            </div>
          </div>
        {% else %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <!-- CENTER: logo (always visible) -->
    <div class="header__logo">
      <a href="/" aria-label="{{ shop.name }}">
        {% if section.settings.logo %}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto" loading="eager">
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- RIGHT: controls -->
    <div class="header__controls">
      <!-- SEARCH: desktop only -->
      <button id="searchBtn" class="header__search-btn" aria-label="Search">SEARCH</button>
      <!-- ACCOUNT: always visible -->
      <div class="acct-wrap">
        <button>ACCOUNT</button>
        <div class="acct-panel">
          {% if customer %}
            <a href="/account">MY ACCOUNT</a>
            <a href="/account/logout">LOGOUT</a>
          {% else %}
            <a href="/account/login">LOGIN</a>
            <a href="/account/register">REGISTER</a>
          {% endif %}
        </div>
      </div>
      <!-- CART: desktop only -->
      <button id="cartBtn" class="header__cart-btn" aria-label="Open cart">CART<span class="cart-count" id="cartCount">{% if cart.item_count > 0 %}({{ cart.item_count }}){% endif %}</span></button>
      <!-- HAMBURGER: hidden, replaced by MENU btn on mobile -->
      <button class="hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>

  </div>
</header>

<!-- SIDEBAR NAV (mobile) -->
<nav class="sidebar-nav" id="sidebarNav" aria-label="Mobile navigation">
  <ul class="sidebar-nav__links">
    {% for link in linklists[section.settings.menu].links %}
      <li>
        <a class="sidebar-nav__link" href="{{ link.url }}">{{ link.title }}</a>
        {% if link.links != blank %}
          <ul class="sidebar-nav__sub">
            {% for child in link.links %}
              <li><a href="{{ child.url }}">{{ child.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
  <div class="sidebar-nav__foot">
    {% if customer %}
      <a href="/account">MY ACCOUNT</a>
      <a href="/account/logout">LOGOUT</a>
    {% else %}
      <a href="/account/login">LOGIN</a>
      <a href="/account/register">REGISTER</a>
    {% endif %}
    <button id="sidebarCartBtn">CART ({{ cart.item_count }})</button>
  </div>
</nav>

<style>
/* ── Mobile: show MENU btn, hide desktop nav + hamburger + search + cart ── */
@media (max-width: 960px) {
  .header__nav        { display: none !important; }
  .hamburger          { display: none !important; }
  .header__search-btn { display: none !important; }
  .header__cart-btn   { display: none !important; }
  .header__menu-btn   { display: block !important; }
}

/* ── Desktop: hide MENU btn ── */
@media (min-width: 961px) {
  .header__menu-btn   { display: none !important; }
}

.header__menu-btn {
  display: none;
  background: none; border: none; cursor: pointer;
  font-family: inherit; font-size: 11px;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: #000; flex: 1; text-align: left;
}

/* ── SIDEBAR ── */
#page-push {
  transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
}
#page-push.pushed {
  transform: translateX(260px);
}
.site-header {
  transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
}
body.sidebar-open .site-header {
  transform: translateX(260px);
}

.sidebar-nav {
  position: fixed;
  top: 0; left: 0; bottom: 0;
  width: 260px;
  background: #fff;
  z-index: 800;
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
  display: flex; flex-direction: column;
  overflow-y: auto;
  border-right: none;
}
.sidebar-nav.open { transform: translateX(0); }

.sidebar-nav__links {
  list-style: none; padding: 32px 0 0; margin: 0;
  display: flex; flex-direction: column; gap: 4px;
  flex: 1;
}

.sidebar-nav__link {
  display: block;
  padding: 8px 28px;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #000;
  border: none;
  transition: opacity 0.2s;
}
.sidebar-nav__link:hover { opacity: 0.45; }

li:has(.sidebar-nav__sub) > .sidebar-nav__link::after {
  content: ' ▶';
  font-size: 6px;
  vertical-align: middle;
  color: #bbb;
  margin-left: 6px;
}

.sidebar-nav__sub {
  list-style: none; padding: 0; margin: 0;
}
.sidebar-nav__sub li a {
  display: block;
  padding: 6px 28px 6px 40px;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #aaa;
  border: none;
  transition: color 0.2s;
}
.sidebar-nav__sub li a:hover { color: #000; }

.sidebar-nav__foot {
  padding: 24px 28px;
  border-top: none;
  display: flex; flex-direction: column; gap: 10px;
}
.sidebar-nav__foot a,
.sidebar-nav__foot button {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #bbb;
  background: none; border: none;
  cursor: pointer; font-family: inherit; text-align: left;
  transition: color 0.2s;
}
.sidebar-nav__foot a:hover,
.sidebar-nav__foot button:hover { color: #000; }
</style>

<script>
(function () {
  const menuBtn     = document.getElementById('menuBtn');
  const sidebarNav  = document.getElementById('sidebarNav');
  const sidebarCart = document.getElementById('sidebarCartBtn');

  function toggleSidebar() {
    const isOpen = sidebarNav.classList.toggle('open');
    document.getElementById('page-push')?.classList.toggle('pushed', isOpen);
    document.body.classList.toggle('sidebar-open', isOpen);
  }
  function closeSidebar() {
    sidebarNav.classList.remove('open');
    document.getElementById('page-push')?.classList.remove('pushed');
    document.body.classList.remove('sidebar-open');
  }

  menuBtn?.addEventListener('click', toggleSidebar);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });

  sidebarCart?.addEventListener('click', () => {
    closeSidebar();
    document.getElementById('cartBtn')?.click();
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo",       "label": "Logo" },
    { "type": "range",        "id": "logo_width", "label": "Logo width", "min": 60, "max": 260, "step": 10, "unit": "px", "default": 100 },
    { "type": "link_list",    "id": "menu",       "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
