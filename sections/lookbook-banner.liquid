<div class="lookbook" data-fade>
  <div class="lookbook__media">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 2400 }}"
           srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1600 }} 1600w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
           sizes="100vw" alt="{{ section.settings.heading | escape }}" loading="lazy">
    {% endif %}
  </div>
  <div class="lookbook__overlay">
    {% if section.settings.label != blank %}<p class="lookbook__label">{{ section.settings.label }}</p>{% endif %}
    {% if section.settings.heading != blank %}<h2 class="lookbook__title">{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.btn != blank %}<a class="lookbook__btn" href="{{ section.settings.btn_url | default: '#' }}">{{ section.settings.btn }}</a>{% endif %}
  </div>
</div>
{% schema %}{"name":"Lookbook Banner","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"label","label":"Label","default":"LOOKBOOK"},{"type":"text","id":"heading","label":"Heading","default":"SS 2025"},{"type":"text","id":"btn","label":"Button","default":"EXPLORE"},{"type":"url","id":"btn_url","label":"Button URL"}],"presets":[{"name":"Lookbook Banner","settings":{"label":"LOOKBOOK","heading":"SS 2025","btn":"EXPLORE"}}]}{% endschema %}