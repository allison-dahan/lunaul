<div class="cat-grid">
  {% for block in section.blocks %}{% if block.type == 'item' %}
  <a class="cat-item" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }} data-fade data-fade-delay="{{ forloop.index }}">
    <div class="cat-item__img">
      {% if block.settings.image != blank %}
        <img src="{{ block.settings.image | image_url: width: 900 }}"
             srcset="{{ block.settings.image | image_url: width: 450 }} 450w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1400 }} 1400w"
             sizes="(max-width:600px) 100vw, 33vw" alt="{{ block.settings.name | escape }}" loading="lazy">
      {% endif %}
    </div>
    <div class="cat-item__label">
      {% if block.settings.sub != blank %}<p class="cat-item__sub">{{ block.settings.sub }}</p>{% endif %}
      {% if block.settings.name != blank %}<p class="cat-item__name">{{ block.settings.name }}</p>{% endif %}
    </div>
  </a>
  {% endif %}{% endfor %}
</div>
{% schema %}{"name":"Category Grid","blocks":[{"type":"item","name":"Category","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"sub","label":"Label","default":"COLLECTION"},{"type":"text","id":"name","label":"Name","default":"NEW ARRIVALS"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Category Grid","blocks":[{"type":"item","settings":{"sub":"SHOP","name":"NEW ARRIVALS"}},{"type":"item","settings":{"sub":"ARCHIVE","name":"PAST SEASONS"}},{"type":"item","settings":{"sub":"SPECIAL","name":"LIMITED EDITION"}}]}]}{% endschema %}